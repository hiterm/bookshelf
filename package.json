{
  "name": "bookshelf",
  "version": "2.11.1",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "concurrently --group 'eslint_d --max-warnings=0 .' 'biome check --assist-enabled false .'",
    "lint:fix": "eslint_d --fix . && biome format . --write",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e-mock-api/tsconfig.json && tsc --noEmit -p e2e-demo-mode/tsconfig.json && tsc --noEmit -p e2e-integration/tsconfig.json",
    "generate": "bash scripts/fetch-schema.sh && graphql-codegen --config codegen.yml && msw init && tsr generate",
    "test:e2e:mock-api": "playwright test",
    "test:e2e:demo-mode": "playwright test --config=playwright.demo.config.ts",
    "test:e2e:mock-api:ui": "playwright test --ui",
    "test:integration": "playwright test --config=playwright.integration.config.ts",
    "integration:up": "bash scripts/integration-up.sh",
    "integration:down": "bash scripts/integration-down.sh"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@auth0/auth0-react": "2.21.0",
    "@mantine/core": "9.4.1",
    "@mantine/form": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@mantine/notifications": "9.4.1",
    "@tabler/icons-react": "3.44.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-table": "8.21.3",
    "dayjs": "1.11.21",
    "graphql": "17.0.2",
    "graphql-request": "7.4.0",
    "mantine-form-zod-resolver": "1.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@eslint/js": "9.39.5",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-graphql-request": "7.1.0",
    "@graphql-codegen/typescript-operations": "6.1.0",
    "@graphql-tools/schema": "10.0.36",
    "@playwright/test": "1.61.1",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-cli": "1.167.18",
    "@tanstack/router-plugin": "1.168.19",
    "@tanstack/table-core": "8.21.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint_d": "15.0.2",
    "graphql-tag": "2.12.7",
    "jose": "6.2.3",
    "jsdom": "29.1.1",
    "msw": "2.15.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vite-plugin-checker": "0.14.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "24.x"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
