{
  "name": "bookshelf",
  "version": "2.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "concurrently --group 'eslint_d --max-warnings=0 .' 'biome check --assist-enabled false .'",
    "lint:fix": "eslint_d --fix . && biome format . --write",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json && tsc --noEmit -p e2e-demo/tsconfig.json",
    "generate": "graphql-codegen --config codegen.yml",
    "test:e2e": "playwright test",
    "test:e2e:demo": "playwright test --config=playwright.demo.config.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@auth0/auth0-react": "2.16.0",
    "@mantine/core": "8.3.18",
    "@mantine/form": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@mantine/notifications": "8.3.18",
    "@tabler/icons-react": "3.41.0",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.7",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-table": "8.21.3",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dayjs": "1.11.20",
    "graphql": "16.13.2",
    "graphql-request": "7.4.0",
    "mantine-form-zod-resolver": "1.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tanstack-table-search-params": "0.12.1",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@eslint/js": "9.39.4",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/typescript": "5.0.9",
    "@graphql-codegen/typescript-graphql-request": "7.0.0",
    "@graphql-codegen/typescript-operations": "5.0.9",
    "@graphql-tools/schema": "10.0.31",
    "@graphql-tools/utils": "11.0.0",
    "@playwright/test": "1.58.2",
    "@tanstack/router-plugin": "1.167.8",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint_d": "15.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "jose": "6.2.2",
    "jsdom": "29.0.1",
    "msw": "2.12.14",
    "typescript-eslint": "8.57.2",
    "vite": "7.3.1",
    "vite-plugin-checker": "0.12.0",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": "24.x"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
