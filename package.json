{
  "name": "bookshelf",
  "version": "2.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "concurrently --group 'eslint_d --max-warnings=0 .' 'biome check --assist-enabled false .'",
    "lint:fix": "eslint_d --fix . && biome format . --write",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json && tsc --noEmit -p e2e-demo/tsconfig.json",
    "generate": "graphql-codegen --config codegen.yml",
    "test:e2e": "playwright test",
    "test:e2e:demo": "playwright test --config=playwright.demo.config.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.3.0",
    "@mantine/core": "^8.1.3",
    "@mantine/form": "^8.1.3",
    "@mantine/hooks": "^8.1.3",
    "@mantine/notifications": "^8.1.3",
    "@tabler/icons-react": "^3.34.0",
    "@tanstack/react-query": "^5.81.5",
    "@tanstack/react-router": "^1.127.3",
    "@tanstack/react-router-devtools": "^1.127.3",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "dayjs": "^1.11.5",
    "graphql": "^16.8.1",
    "graphql-request": "^7.4.0",
    "mantine-form-zod-resolver": "^1.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tanstack-table-search-params": "^0.9.0",
    "typescript": "~5.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.1",
    "@eslint/js": "^9.31.0",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-graphql-request": "^7.0.0",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-tools/schema": "^10.0.31",
    "@graphql-tools/utils": "^11.0.0",
    "@playwright/test": "^1.58.2",
    "@tanstack/router-plugin": "^1.127.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.31.0",
    "eslint_d": "^14.3.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jose": "^6.2.2",
    "jsdom": "^26.1.0",
    "msw": "^2.12.13",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.10.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "24.x"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
