{
  "agent": {
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "always_allow": [
            { "pattern": "^npm\\s+test($|\\s)" },
            {
              "pattern": "^npm\\s+run\\s+(lint|test|typecheck|test:e2e|test:e2e:demo)($|\\s)"
            }
          ]
        }
      }
    }
  }
}
